<resources>
    <!-- Base application theme. Full Compose theming lives in NSTheme.kt (AND-002). -->
    <style name="Theme.NativeStream" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- Launch-time theme: system splash screen (API 31+), falls back to a
         plain themed window pre-API 31. Swapped to Theme.NativeStream in
         MainActivity.onCreate via installSplashScreen(). -->
    <style name="Theme.NativeStream.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/icon</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/black</item>
        <item name="postSplashScreenTheme">@style/Theme.NativeStream</item>
    </style>
</resources>